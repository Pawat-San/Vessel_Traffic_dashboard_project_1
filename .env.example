# Server Configuration
PORT=3000
NODE_ENV=development

# Security & Secrets
JWT_SECRET=super-secret-jwt-key-replace-in-production
JWT_REFRESH_SECRET=super-secret-jwt-refresh-key-replace-in-production
COOKIE_SECRET=super-secret-cookie-key-replace-in-production

# Security Header Config (CORS)
CORS_ORIGIN=http://localhost:3000

# Rate Limiter
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes
RATE_LIMIT_MAX=100 # limit each IP to 100 requests per windowMs

# Database Client Selection: 'sqlite' (default, local dev) or 'pg' (production)
DB_CLIENT=sqlite

# SQLite (used when DB_CLIENT=sqlite)
DB_PATH=data/dashboard.db

# PostgreSQL (used when DB_CLIENT=pg)
# For Supabase: Project Settings -> Database -> Connection string ("URI" tab
# has the individual host/port/user/password/database fields broken out too).
# Use the "Session pooler" host/port (not "Transaction pooler") -- this app
# keeps a small long-lived connection pool, which the session pooler supports
# cleanly; the transaction pooler restricts prepared statements Knex relies on.
# Supabase requires SSL, so DB_SSL must be true.
DB_HOST=localhost
DB_PORT=5432
DB_USER=vessel_dashboard
DB_PASSWORD=change-me
DB_NAME=vessel_dashboard
DB_SSL=false

# Superadmin bootstrap (REQUIRED the first time the users table is empty)
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=change-me-now

# Optional demo accounts for local dev only (opt-in, off by default)
SEED_DEMO_ACCOUNTS=false
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=
# OPERATOR_USERNAME=operator
# OPERATOR_PASSWORD=
# VIEWER_USERNAME=viewer
# VIEWER_PASSWORD=
