{
  "name": "vessel-dashboard",
  "version": "1.0.0",
  "description": "Enterprise-Grade Vessel Traffic Dashboard SPA",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --runInBand --detectOpenHandles --forceExit",
    "test:coverage": "jest --runInBand --detectOpenHandles --forceExit --coverage",
    "db:migrate": "node src/database/migrations/runner.js",
    "db:seed": "node src/database/seeds/runner.js",
    "db:reset": "node -e \"const fs = require('fs'); try { fs.unlinkSync('data/dashboard.db'); fs.unlinkSync('data/dashboard.db-wal'); fs.unlinkSync('data/dashboard.db-shm'); console.log('DB deleted'); } catch(e) {}\" && npm run db:migrate && npm run db:seed",
    "lint": "eslint src/**/*.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "node-cache": "^5.1.2",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0",
    "yamljs": "^0.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "private": true
}
